model User {
  id              String         @id @default(uuid())
  email           String         @unique
  name            String?
  passwordHash    String?
  cognitiveState  String         @default("BEGINNER")
  createdAt       DateTime       @default(now())

  courses         Course[]
  progress        UserProgress[]
  analytics       Analytics[]
  topicStates     TopicState[]
  courseProgress  UserCourseProgress[]
  reviews         RatingReview[]
}

model TopicState {
  id              String   @id @default(uuid())
  userId          String
  topic           String
  cognitiveState  String   @default("BEGINNER")
  emaScore        Float    @default(0)
  totalQuizzes    Int      @default(0)
  updatedAt       DateTime @default(now()) @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topic])
}

model Course {
  id               String         @id @default(uuid())
  userId           String
  title            String
  targetDifficulty String
  coverImage       String?
  createdAt        DateTime       @default(now())
  averageRating    Float          @default(0)
  totalRatings     Int            @default(0)
  recommendationSourceId String?
  recommendationUserId   String?

  user             User           @relation(fields: [userId], references: [id])
  modules          Module[]
  ratings          RatingReview[]
  userProgress     UserCourseProgress[]
}

model Module {
  id               String         @id @default(uuid())
  courseId         String
  title            String
  content          String?
  youtubeUrl       String?
  orderIndex       Int
  difficultyWeight Int            @default(1)

  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningAids     LearningAid[]
  userProgress     UserProgress[]
}

model LearningAid {
  id       String          @id @default(uuid())
  moduleId String
  type     String
  payload  Json

  module   Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id                 String         @id @default(uuid())
  userId             String
  moduleId           String
  status             String         @default("NOT_STARTED")
  quizScore          Float?
  confidenceRating   Int?            // 1-5 confidence after quiz
  timeSpentSeconds   Int            @default(0)
  metadata           Json?
  completedAt        DateTime?

  user               User           @relation(fields: [userId], references: [id])
  module             Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
}

model Analytics {
  id         String   @id @default(uuid())
  userId     String
  metricType String
  value      Float
  recordedAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
}

model UserCourseProgress {
  id                    String   @id @default(uuid())
  userId                String
  courseId              String
  isCompleted           Boolean  @default(false)
  completedAt           DateTime?
  totalTimeSpentSeconds Int      @default(0)
  averageQuizScore      Float?   // Percentage 0-100
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model RatingReview {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  rating    Int      // 1-5
  review    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}
